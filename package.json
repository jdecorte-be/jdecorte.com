{
  "name": "jdecorte.com",
  "version": "4.1.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "next dev",
    "dev": "contentlayer2 build && cross-env INIT_CWD=$PWD next dev",
    "build": "node -e \"if(process.env.NODE_ENV!=='production'){console.error('NODE_ENV must be production');process.exit(1)}\" && contentlayer2 build && cross-env INIT_CWD=$PWD next build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "build:content": "contentlayer2 build",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "biome check --write app components lib layouts scripts"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.4.0",
    "@floating-ui/react": "^0.27.18",
    "@next/bundle-analyzer": "16.1.6",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/forms": "^0.5.4",
    "@tailwindcss/typography": "^0.5.9",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "autoprefixer": "^10.4.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contentlayer2": "^0.5.8",
    "esbuild": "^0.25.2",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.2",
    "image-size": "^1.2.1",
    "kbar": "^0.1.0-beta.48",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "pliny": "^0.4.1",
    "postcss": "^8.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.5.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-preset-minify": "^7.0.1",
    "rehype-prism-plus": "^2.0.1",
    "rehype-slug": "^6.0.0",
    "remark": "^14.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.0",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^4.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@svgr/webpack": "^8.0.1",
    "@types/mdx": "^2.0.5",
    "@types/node": "25.0.3",
    "@types/react": "^19.2.14",
    "animate-ui": "^0.0.4",
    "bun-types": "^1.3.10",
    "cross-env": "^7.0.3",
    "husky": "^8.0.0",
    "lint-staged": "^13.0.0",
    "typescript": "^5.1.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{md,mdx}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@opentelemetry/api": "1.4.1",
    "@opentelemetry/core": "1.13.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.39.1",
    "@opentelemetry/resources": "1.13.0",
    "@opentelemetry/sdk-trace-base": "1.13.0",
    "@opentelemetry/sdk-trace-node": "1.13.0",
    "@opentelemetry/semantic-conventions": "1.13.0",
    "@types/react": "$@types/react"
  }
}
